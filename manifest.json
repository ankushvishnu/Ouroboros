{
  "manifest_version": 3,
  "name": "Ouroboros",
  "version": "0.1.0",
  "description": "Human-approved prompt optimization. Improve what you send to AI — always with your eyes open.",

  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },

  "action": {
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    },
    "default_title": "Ouroboros — Prompt Optimizer"
  },

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/provenance.js",
        "content/interceptor.js",
        "content/drawer-injector.js",
        "content/content.js"
      ],
      "css": ["styles/content.css"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "clipboardRead"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "drawer/drawer.html",
        "assets/fonts/*",
        "assets/icons/*",
        "styles/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "chrome_url_overrides": {}
}
